[core]
  editor       = vim
  pager        = less
  excludesfile = ~/.gitignore
[alias]
  a            = add --ignore-removal
  dry          = add --all --dry-run
  update       = add --all
  d            = diff --minimal
  changed      = diff --diff-filter=MR
  ls           = ls-tree -r --name-only HEAD
  la           = ls-tree -r --name-only HEAD
  s            = status
  ss           = status --short
[color]
  status = auto
  diff   = auto
  branch = auto
  ui     = auto
[push]
  default = simple
[http]
  postBuffer = 104857600
