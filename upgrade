#!/bin/sh

echo '                                    __'
echo '  __  ______  ____ __________ _____/ /__'
echo ' / / / / __ \/ __ `/ ___/ __ `/ __  / _ \'
echo '/ /_/ / /_/ / /_/ / /  / /_/ / /_/ /  __/'
echo '\__,_/ .___/\__, /_/   \__,_/\__,_/\___/'
echo '    /_/__  /____/  _____ __'
echo '  ____/ /___  / /_/ __(_) /__  _____'
echo ' / __  / __ \/ __/ /_/ / / _ \/ ___/'
echo '/ /_/ / /_/ / /_/ __/ / /  __(__  )'
echo '\__,_/\____/\__/_/ /_/_/\___/____/'
echo ''

if [ ! -n "`ls .git 2>/dev/null`" ]; then
  echo "'`pwd`' isnt working directory."
  exit 2
fi

if [ ! -s `which git` ]; then
  echo 'Your system lack of git.'
  if [ ! -s `which git`]; then
    echo 'Xcode.app -> Preference -> Install "Command Line Tools"'
    exit 2
  else
    echo 'Install git.'
    sudo apt-get install git
  fi
fi

echo ''
echo '#====================#'
echo '# Rebase Repository  #'
echo '#====================#'
git stash clear
git stash
git pull --rebase

echo ''
echo '#====================#'
echo '# Replace Rcfiles    #'
echo '#====================#'
rm -f ~/.screenrc && ln -s ./screenrc ~/.screenrc && echo 'o -> ~/.screenrc'
rm -f ~/.vim      && ln -s ./vim      ~/.vim      && echo 'o -> ~/.vim/'
rm -f ~/.vimrc    && ln -s ./vimrc    ~/.vimrc    && echo 'o -> ~/.vimrc'
rm -f ~/.zsh      && ln -s ./zsh      ~/.zsh      && echo 'o -> ~/.zsh/'
rm -f ~/.zshrc    && ln -s ./zshrc    ~/.zshrc    && echo 'o -> ~/.zshrc'
rm -f ~/.zshenv   && ln -s ./zshenv   ~/.zshenv   && echo 'o -> ~/.zshenv'

echo ''
echo '#====================#'
echo '# Update submodules  #'
echo '#====================#'
git submodule init
git submodule update
git submodule foreach 'git pull origin master'

echo ''
echo '#=====================#'
echo '# Install Vim Bundles #'
echo '#=====================#'
echo 'Vundle: Installing bundles...'
echo ':BundleInstall' | vim > /dev/null 2>&1
echo 'Vundle: Cleaning bundles...'
echo ':BundleClean'   | vim > /dev/null 2>&1

if [ $OSTYPE[0,6] = 'darwin' ]; then
  echo ''
  echo '#====================#'
  echo '# Check Brew         #'
  echo '#====================#'
  if [ ! -s `which brew` ]; then
    echo 'Install homebrew.'
    ruby <(curl -fsSkL raw.github.com/mxcl/homebrew/go)
    sudo chown $USER -R /usr/local
    brew doctor
    echo 'Install coreutils, htop.'
    brew install coreutils htop 2>&1 >/dev/null
  else
    echo 'Update homebrew.'
    brew update
  fi
else
  if [ ! -s `which htop` ]; then
    echo 'Install htop.'
    sudo apt-get install htop
  fi
fi

echo ''
echo '#=====================#'
echo '# Retouch Alters      #'
echo '#=====================#'
git stash pop

echo ''
echo '#=====================#'
echo '# Upgrade Done        #'
echo '#=====================#'
echo ''
